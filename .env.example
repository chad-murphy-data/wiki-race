# Hostname of the deployed Cloudflare Worker that runs the room server.
# Set this in production (Netlify env vars) to whatever wrangler prints
# after `npx wrangler deploy` — e.g. wiki-race.your-subdomain.workers.dev
# For local dev with `wrangler dev`, the client falls back to
# 127.0.0.1:8787 automatically, so you can leave this empty.
NEXT_PUBLIC_WORKER_HOST=
